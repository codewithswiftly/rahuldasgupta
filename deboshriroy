<script>
  const tl = document.getElementById('timeline');
  const io = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if(e.isIntersecting){
        tl.classList.add('in-view');
        io.disconnect();
      }
    });
  }, {threshold:0.15});
  io.observe(tl);
</script>


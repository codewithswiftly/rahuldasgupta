<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Deboshri Roy — Territory Business Manager</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,500;0,9..144,600;1,9..144,400;1,9..144,500&family=Work+Sans:wght@300;400;500;600&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
  :root{
    --ink:#16332C;
    --paper:#F6F1E4;
    --paper-2:#EFE8D6;
    --gold:#B5822E;
    --sage:#7E9A82;
    --charcoal:#262420;
    --rule:#D8CFB8;
    --paper-rgb: 246,241,228;
  }

  *{box-sizing:border-box;}
  html{scroll-behavior:smooth;}
  body{
    margin:0;
    background:var(--paper);
    color:var(--charcoal);
    font-family:'Work Sans', sans-serif;
    font-weight:400;
    line-height:1.6;
    -webkit-font-smoothing:antialiased;
  }

  ::selection{background:var(--gold); color:var(--paper);}

  a{color:inherit;}

  .wrap{
    max-width:920px;
    margin:0 auto;
    padding:0 32px;
  }

  /* focus visibility */
  a:focus-visible, button:focus-visible{
    outline:2px solid var(--gold);
    outline-offset:3px;
  }

  @media (prefers-reduced-motion: reduce){
    *{animation-duration:0.01ms !important; animation-iteration-count:1 !important; transition-duration:0.01ms !important; scroll-behavior:auto !important;}
  }

  /* ---------- top rule bar ---------- */
  .label-bar{
    background:var(--ink);
    color:var(--paper-2);
    font-family:'IBM Plex Mono', monospace;
    font-size:11px;
    letter-spacing:0.14em;
    text-transform:uppercase;
    padding:10px 0;
  }
  .label-bar .wrap{
    display:flex;
    justify-content:space-between;
    flex-wrap:wrap;
    gap:8px;
  }
  .label-bar span{opacity:0.85;}

  /* ---------- hero ---------- */
  header.hero{
    padding:76px 0 64px;
    position:relative;
  }
  .rx-card{
    background:var(--paper);
    border-top:3px double var(--gold);
    border-bottom:1px solid var(--rule);
    padding:48px 0 40px;
    position:relative;
  }
  .eyebrow{
    font-family:'IBM Plex Mono', monospace;
    font-size:12px;
    letter-spacing:0.16em;
    text-transform:uppercase;
    color:var(--gold);
    margin:0 0 18px;
  }
  .hero-grid{
    display:grid;
    grid-template-columns:1fr auto;
    gap:40px;
    align-items:end;
  }
  h1.name{
    font-family:'Fraunces', serif;
    font-weight:500;
    font-style:italic;
    font-size:clamp(44px, 7vw, 78px);
    line-height:0.98;
    margin:0 0 14px;
    color:var(--ink);
    letter-spacing:-0.01em;
  }
  .role-line{
    font-family:'IBM Plex Mono', monospace;
    font-size:14px;
    letter-spacing:0.04em;
    color:var(--charcoal);
    margin:0 0 22px;
  }
  .role-line .sep{color:var(--sage); margin:0 8px;}

  .tagline{
    font-family:'Fraunces', serif;
    font-weight:400;
    font-size:20px;
    line-height:1.5;
    max-width:52ch;
    color:var(--charcoal);
    margin:0;
  }

  .portrait{
    width:118px;
    height:154px;
    object-fit:cover;
    border:1px solid var(--rule);
    box-shadow:6px 6px 0 var(--paper-2), 6px 6px 0 1px var(--rule);
    filter:sepia(8%) saturate(90%);
  }

  .stat-row{
    display:flex;
    gap:0;
    margin-top:40px;
    border-top:1px solid var(--rule);
    border-bottom:1px solid var(--rule);
  }
  .stat{
    flex:1;
    padding:18px 0 16px;
    border-right:1px solid var(--rule);
  }
  .stat:last-child{border-right:none;}
  .stat b{
    display:block;
    font-family:'Fraunces', serif;
    font-size:28px;
    font-weight:500;
    color:var(--ink);
  }
  .stat span{
    font-family:'IBM Plex Mono', monospace;
    font-size:11px;
    text-transform:uppercase;
    letter-spacing:0.08em;
    color:var(--sage);
  }

  /* ---------- section headings ---------- */
  .section{
    padding:72px 0;
  }
  .section + .section{
    border-top:1px solid var(--rule);
  }
  .section-head{
    display:flex;
    align-items:baseline;
    gap:16px;
    margin-bottom:44px;
  }
  .section-head .tag{
    font-family:'IBM Plex Mono', monospace;
    font-size:11px;
    letter-spacing:0.14em;
    text-transform:uppercase;
    color:var(--gold);
    white-space:nowrap;
  }
  .section-head h2{
    font-family:'Fraunces', serif;
    font-weight:500;
    font-size:32px;
    margin:0;
    color:var(--ink);
  }
  .section-head::after{
    content:"";
    flex:1;
    height:1px;
    background:var(--rule);
  }

  /* ---------- timeline ---------- */
  .timeline{
    position:relative;
    padding-left:64px;
  }
  .timeline svg{
    position:absolute;
    left:0;
    top:0;
    height:100%;
    width:64px;
    overflow:visible;
  }
  .track-path{
    fill:none;
    stroke:var(--sage);
    stroke-width:2;
    stroke-linecap:round;
    stroke-dasharray:1400;
    stroke-dashoffset:1400;
    transition:stroke-dashoffset 1.6s ease;
  }
  .timeline.in-view .track-path{
    stroke-dashoffset:0;
  }

  .role{
    position:relative;
    padding:0 0 56px 28px;
  }
  .role:last-child{padding-bottom:4px;}
  .role .marker{
    position:absolute;
    left:-64px;
    top:2px;
    width:14px;
    height:14px;
    border-radius:50%;
    background:var(--paper);
    border:2.5px solid var(--gold);
    transform:scale(0);
    transition:transform 0.4s ease 0.3s;
  }
  .timeline.in-view .role .marker{transform:scale(1);}

  .role .when{
    font-family:'IBM Plex Mono', monospace;
    font-size:12px;
    letter-spacing:0.05em;
    color:var(--gold);
    margin:0 0 6px;
  }
  .role h3{
    font-family:'Fraunces', serif;
    font-weight:500;
    font-size:23px;
    margin:0 0 4px;
    color:var(--ink);
  }
  .role .org{
    font-weight:500;
  }
  .role .where{
    font-size:14px;
    color:#5a5648;
    margin:0 0 14px;
  }
  .role p.desc{
    max-width:60ch;
    margin:0 0 14px;
    font-size:15px;
  }
  .tags{
    display:flex;
    flex-wrap:wrap;
    gap:8px;
  }
  .tags span{
    font-family:'IBM Plex Mono', monospace;
    font-size:11px;
    letter-spacing:0.04em;
    padding:5px 10px;
    background:var(--paper-2);
    border:1px solid var(--rule);
    color:var(--ink);
  }

  /* ---------- two column: education + profile ---------- */
  .two-col{
    display:grid;
    grid-template-columns:1.3fr 1fr;
    gap:56px;
  }

  .ledger{
    width:100%;
    border-collapse:collapse;
  }
  .ledger caption{
    text-align:left;
    font-family:'IBM Plex Mono', monospace;
    font-size:11px;
    letter-spacing:0.1em;
    text-transform:uppercase;
    color:var(--sage);
    margin-bottom:14px;
  }
  .ledger th{
    text-align:left;
    font-family:'IBM Plex Mono', monospace;
    font-size:11px;
    letter-spacing:0.06em;
    text-transform:uppercase;
    color:var(--sage);
    padding:0 12px 10px 0;
    border-bottom:1px solid var(--ink);
    font-weight:500;
  }
  .ledger td{
    padding:14px 12px 14px 0;
    border-bottom:1px solid var(--rule);
    vertical-align:top;
    font-size:14.5px;
  }
  .ledger td.exam{
    font-family:'Fraunces', serif;
    font-size:16px;
    color:var(--ink);
  }
  .ledger td.pct{
    font-family:'IBM Plex Mono', monospace;
    color:var(--gold);
    white-space:nowrap;
  }
  .ledger td.yr{
    font-family:'IBM Plex Mono', monospace;
    white-space:nowrap;
  }

  .profile-block{margin-bottom:34px;}
  .profile-block:last-child{margin-bottom:0;}
  .profile-block h4{
    font-family:'IBM Plex Mono', monospace;
    font-size:11px;
    letter-spacing:0.1em;
    text-transform:uppercase;
    color:var(--sage);
    margin:0 0 12px;
  }
  .strengths{
    list-style:none;
    margin:0;
    padding:0;
  }
  .strengths li{
    position:relative;
    padding-left:20px;
    margin-bottom:10px;
    font-size:15px;
  }
  .strengths li::before{
    content:"—";
    position:absolute;
    left:0;
    color:var(--gold);
  }
  .pill-row{
    display:flex;
    flex-wrap:wrap;
    gap:8px;
  }
  .pill-row span{
    font-size:13px;
    padding:6px 12px;
    border:1px solid var(--rule);
    color:var(--ink);
    background:var(--paper);
  }

  /* ---------- contact / footer ---------- */
  footer{
    background:var(--ink);
    color:var(--paper-2);
    padding:56px 0 40px;
  }
  footer .foot-head{
    font-family:'Fraunces', serif;
    font-style:italic;
    font-weight:400;
    font-size:26px;
    color:var(--paper);
    margin:0 0 28px;
  }
  .contact-grid{
    display:grid;
    grid-template-columns:repeat(auto-fit, minmax(200px,1fr));
    gap:24px;
    border-top:1px solid rgba(246,241,228,0.18);
    padding-top:28px;
  }
  .contact-grid div h5{
    font-family:'IBM Plex Mono', monospace;
    font-size:10.5px;
    letter-spacing:0.1em;
    text-transform:uppercase;
    color:var(--sage);
    margin:0 0 8px;
    font-weight:500;
  }
  .contact-grid div p{
    margin:0;
    font-size:14.5px;
    color:var(--paper-2);
  }
  .contact-grid a{
    text-decoration:none;
    border-bottom:1px solid var(--gold);
  }
  .sign-off{
    margin-top:36px;
    font-family:'IBM Plex Mono', monospace;
    font-size:11px;
    color:rgba(246,241,228,0.55);
    display:flex;
    justify-content:space-between;
    flex-wrap:wrap;
    gap:8px;
  }

  /* ---------- responsive ---------- */
  @media (max-width:760px){
    .wrap{padding:0 20px;}
    .hero-grid{grid-template-columns:1fr; gap:24px;}
    .portrait{order:-1;}
    .stat-row{flex-wrap:wrap;}
    .stat{flex:1 1 50%; border-bottom:1px solid var(--rule);}
    .two-col{grid-template-columns:1fr; gap:44px;}
    .timeline{padding-left:48px;}
    .timeline svg{width:48px;}
    .role{padding-left:20px;}
    .role .marker{left:-48px;}
  }
</style>
</head>
